# InvestEdge - configurazione dati reali (LOCALE, NON committare con chiavi vere)
#
# Come usarlo:
#   1. Copia questo file in backend/.env
#   2. Inserisci le tue API key (vedi link sotto)
#   3. Riavvia Avvia-InvestEdge.bat
#   4. Apri la pagina Dati e clicca "Aggiorna tutti i dati"
#
# Tier gratuiti sufficienti per iniziare:
#   Alpha Vantage (azioni/ETF/news): https://www.alphavantage.co/support/#api-key
#   CoinGecko (cripto, anche senza key): https://www.coingecko.com/en/api
#   FRED (tassi/bond, opzionale):        https://fred.stlouisfed.org/docs/api/api_key.html

# Attiva le chiamate reali (false = solo dati seed/demo)
ENABLE_REAL_DATA=false
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=

# Cache e limiti giornalieri (proteggono dai rate limit dei tier gratuiti)
API_CACHE_TTL_HOURS=24
ALPHA_VANTAGE_DAILY_LIMIT=20
COINGECKO_DAILY_LIMIT=100
FRED_DAILY_LIMIT=100

# News reali (usano la chiave Alpha Vantage)
ENABLE_REAL_NEWS=false
NEWS_CACHE_TTL_HOURS=6
NEWS_DAILY_LIMIT=20
NEWS_SENTIMENT_WEIGHT=5
