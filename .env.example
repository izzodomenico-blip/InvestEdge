INVESTEDGE_APP_NAME=InvestEdge API
INVESTEDGE_ENV=local
INVESTEDGE_API_VERSION=0.1.0
INVESTEDGE_DB_PATH=data/investedge.db
INVESTEDGE_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
INVESTEDGE_CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):517\d+$

VITE_API_BASE_URL=http://127.0.0.1:8001

ENABLE_REAL_DATA=false
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=
FRED_API_KEY=
API_CACHE_TTL_HOURS=24
ALPHA_VANTAGE_DAILY_LIMIT=20
COINGECKO_DAILY_LIMIT=100
FRED_DAILY_LIMIT=100

ENABLE_REAL_NEWS=false
NEWS_CACHE_TTL_HOURS=6
NEWS_DAILY_LIMIT=20
NEWS_SENTIMENT_WEIGHT=5

# GOOGLE SHEETS IMPORT (Step 19)
ENABLE_GOOGLE_SHEETS_IMPORT=false
GOOGLE_SHEETS_AUTH_MODE=oauth_desktop
GOOGLE_SHEETS_OAUTH_CREDENTIALS_PATH=backend/secrets/google_oauth_credentials.json
GOOGLE_SHEETS_TOKEN_PATH=backend/secrets/google_token.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_PORTFOLIO_RANGE=PORTFOLIO!A:Z
GOOGLE_SHEETS_TRANSACTIONS_RANGE=TRANSACTIONS!A:Z
GOOGLE_SHEETS_CASH_RANGE=CASH!A:Z
GOOGLE_SHEETS_WATCHLIST_RANGE=WATCHLIST!A:Z
